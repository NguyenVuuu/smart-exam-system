```gitignore
# =========================
# Dependencies
# =========================
node_modules/

# =========================
# Environment Variables
# =========================
.env
.env.*
!.env.example

# =========================
# Build Output
# =========================
dist/
build/
coverage/

# =========================
# Logs
# =========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# Cache
# =========================
.cache/
.vite/
.eslintcache

# =========================
# Runtime
# =========================
*.pid
*.pid.lock

# =========================
# IDE
# =========================
.vscode/
.idea/

# =========================
# OS
# =========================
.DS_Store
Thumbs.db

# =========================
# Temporary files
# =========================
*.tmp
*.temp
*.swp
*.swo

# =========================
# Testing
# =========================
.nyc_output/

# =========================
# Optional package manager cache
# =========================
.pnpm-store/
.yarn/
```
