generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(uuid())
  email           String?
  phoneNumber     String?
  password        String
  fullName        String
  studentCode     String?          @unique
  teacherCode     String?          @unique
  isAdmin         Boolean          @default(false)
  avatarUrl       String?
  status          UserStatus       @default(ACTIVE)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  auditLogs       AuditLog[]
  courseOfferings CourseOffering[] @relation("TeacherCourseOfferings")
  enrollments     Enrollment[]     @relation("StudentEnrollments")
  exams           Exam[]           @relation("CreatorExams")
  examAttempts    ExamAttempt[]    @relation("StudentExamAttempts")
  materials       Material[]       @relation("UploaderMaterials")
  notifications   Notification[]
  questions       Question[]       @relation("OwnerQuestions")
}

model CodeGenerationSetting {
  id            String   @id @default("SYSTEM")

  studentPrefix String   @default("SV")
  studentDigits Int      @default(6)

  teacherPrefix String   @default("GV")
  teacherDigits Int      @default(6)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Semester {
  id              String           @id @default(uuid())
  name            String
  startDate       DateTime
  endDate         DateTime
  status          SemesterStatus   @default(UPCOMING)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  courseOfferings CourseOffering[]
}

model Subject {
  id              String           @id @default(uuid())
  code            String           @unique
  name            String
  description     String?
  status          SubjectStatus    @default(ACTIVE)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  courseOfferings CourseOffering[]
  questions       Question[]
}

model CourseOffering {
  id          String               @id @default(uuid())
  code        String               @unique
  status      CourseOfferingStatus @default(ACTIVE)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  semesterId  String
  subjectId   String
  teacherId   String
  semester    Semester             @relation(fields: [semesterId], references: [id])
  subject     Subject              @relation(fields: [subjectId], references: [id])
  teacher     User                 @relation("TeacherCourseOfferings", fields: [teacherId], references: [id])
  enrollments Enrollment[]
  exams       Exam[]
  materials   Material[]

  @@index([teacherId])
  @@index([semesterId])
  @@index([subjectId])
}

model Enrollment {
  id               String         @id @default(uuid())
  enrolledAt       DateTime       @default(now())
  courseOfferingId String
  studentId        String
  courseOffering   CourseOffering @relation(fields: [courseOfferingId], references: [id])
  student          User           @relation("StudentEnrollments", fields: [studentId], references: [id])

  @@unique([courseOfferingId, studentId])
  @@index([studentId])
}

model Material {
  id               String         @id @default(uuid())
  fileName         String
  objectName       String
  fileSize         Int
  contentType      String
  storagePath      String
  aiEnabled        Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  courseOfferingId String
  uploaderId       String
  courseOffering   CourseOffering @relation(fields: [courseOfferingId], references: [id])
  uploader         User           @relation("UploaderMaterials", fields: [uploaderId], references: [id])

  @@unique([courseOfferingId, fileName])
}

model Question {
  id               String                @id @default(uuid())
  content          String
  explanation      String?
  type             QuestionType
  difficulty       QuestionDifficulty
  source           QuestionSource
  language         ProgrammingLanguage?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  ownerId          String
  subjectId        String
  attemptQuestions ExamAttemptQuestion[]
  examQuestions    ExamQuestion[]
  programmingTests ProgrammingTestCase[]
  owner            User                  @relation("OwnerQuestions", fields: [ownerId], references: [id])
  subject          Subject               @relation(fields: [subjectId], references: [id])
  options          QuestionOption[]
  studentAnswers   StudentAnswer[]

  @@index([ownerId])
  @@index([subjectId])
  @@index([type])
}

model QuestionOption {
  id         String   @id @default(uuid())
  content    String
  isCorrect  Boolean  @default(false)
  questionId String
  question   Question @relation(fields: [questionId], references: [id])

  @@index([questionId])
}

model ProgrammingTestCase {
  id             String   @id @default(uuid())
  input          String
  expectedOutput String
  weight         Decimal  @db.Decimal(5,2)
  isHidden       Boolean  @default(false)
  questionId     String
  question       Question @relation(fields: [questionId], references: [id])

  @@index([questionId])
}

model Exam {
  id                      String         @id @default(uuid())
  title                   String
  description             String?
  password                String?
  startTime               DateTime
  endTime                 DateTime
  durationMinutes         Int
  maxAttempts             Int            @default(1)
  shuffleQuestions        Boolean        @default(false)
  shuffleOptions          Boolean        @default(false)
  showResultImmediately   Boolean        @default(false)
  allowReviewBeforeSubmit Boolean        @default(false)
  status                  ExamStatus     @default(DRAFT)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  courseOfferingId        String
  createdById             String
  courseOffering          CourseOffering @relation(fields: [courseOfferingId], references: [id])
  createdBy               User           @relation("CreatorExams", fields: [createdById], references: [id])
  examAttempts            ExamAttempt[]
  examQuestions           ExamQuestion[]

  @@index([courseOfferingId])
  @@index([createdById])
  @@index([status])
}

model ExamQuestion {
  id         String   @id @default(uuid())
  points     Decimal  @db.Decimal(5,2)
  examId     String
  questionId String
  exam       Exam     @relation(fields: [examId], references: [id])
  question   Question @relation(fields: [questionId], references: [id])

  @@unique([examId, questionId])

  @@index([examId])
  @@index([questionId])
}

model ExamAttempt {
  id               String                @id @default(uuid())
  attemptNo        Int
  startedAt        DateTime              @default(now())
  submittedAt      DateTime?
  remainingSeconds Int
  lastSavedAt      DateTime?
  endedBy          AttemptEndedBy?
  status           AttemptStatus         @default(IN_PROGRESS)
  totalScore       Decimal?              @db.Decimal(5,2)
  autoScore        Decimal?              @db.Decimal(5,2)
  manualScore      Decimal?              @db.Decimal(5,2)
  isPublished      Boolean               @default(false)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  examId           String
  studentId        String
  exam             Exam                  @relation(fields: [examId], references: [id])
  student          User                  @relation("StudentExamAttempts", fields: [studentId], references: [id])
  attemptQuestions ExamAttemptQuestion[]
  examSessions     ExamSession[]
  studentAnswers   StudentAnswer[]
  violations       Violation[]

  @@unique([examId, studentId, attemptNo])
  @@index([studentId])
  @@index([examId])
}

model ExamAttemptQuestion {
  id         String      @id @default(uuid())
  orderIndex Int
  attemptId  String
  questionId String
  attempt    ExamAttempt @relation(fields: [attemptId], references: [id])
  question   Question    @relation(fields: [questionId], references: [id])

  @@unique([attemptId, questionId])
  @@unique([attemptId, orderIndex])
  @@index([attemptId])
  @@index([questionId])
}

model ExamSession {
  id            String      @id @default(uuid())
  socketId      String?
  ipAddress     String
  deviceInfo    String
  lastHeartbeat DateTime
  isOnline      Boolean     @default(false)
  createdAt     DateTime    @default(now())
  attemptId     String      @unique
  attempt       ExamAttempt @relation(fields: [attemptId], references: [id])
}

model StudentAnswer {
  id                     String                  @id @default(uuid())
  sourceCode             String?
  selectedOptionIds      Json?
  essayAnswer            String?
  score                  Decimal?                @db.Decimal(5,2)
  isCorrect              Boolean?
  attemptId              String
  questionId             String
  attempt                ExamAttempt             @relation(fields: [attemptId], references: [id])
  question               Question                @relation(fields: [questionId], references: [id])

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
}



model Violation {
  id            String        @id @default(uuid())
  violationType ViolationType
  severity      SeverityLevel
  evidenceUrls  Json
  description   String?
  detectedAt    DateTime      @default(now())
  attemptId     String
  attempt       ExamAttempt   @relation(fields: [attemptId], references: [id])

  @@index([attemptId])
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  entityType String
  entityId   String
  metadata   Json
  createdAt  DateTime @default(now())
  userId     String
  ipAddress  String?
  userAgent  String?
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
}



enum UserStatus {
  ACTIVE
  INACTIVE
}

enum SemesterStatus {
  UPCOMING
  ACTIVE
  CLOSED
}

enum SubjectStatus {
  ACTIVE
  INACTIVE
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  PROGRAMMING
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionSource {
  MANUAL
  AI_GENERATED
  IMPORTED
}

enum ProgrammingLanguage {
  JAVA
  C
  CPP
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  EXPIRED
}

enum AttemptEndedBy {
  STUDENT
  TIMEOUT
  SYSTEM
}

enum ViolationType {
  TAB_SWITCH
  FULLSCREEN_EXIT
  NO_FACE
  MULTIPLE_FACES
  INACTIVITY
}

enum SeverityLevel {
  LOW
  MEDIUM
  HIGH
}

enum CourseOfferingStatus {
  ACTIVE
  CLOSED
}
